# Meta Ads MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Meta Graph API access token
# Get yours at: https://developers.facebook.com/tools/explorer/
# Required permissions: ads_read
META_ACCESS_TOKEN=

# Optional: API version (default: v22.0)
# META_API_VERSION=v22.0

# Optional: Rate limit per hour (default: 200)
# META_RATE_LIMIT_PER_HOUR=200

# Optional: Log level (default: INFO)
# LOG_LEVEL=INFO

# Optional: Debug mode (default: false)
# DEBUG=false
